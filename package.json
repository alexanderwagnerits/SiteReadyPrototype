{
  "name": "siteready-prototype",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "dev": "react-scripts start",
    "build": "CI=false react-scripts build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\" \"functions/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css}\" \"functions/**/*.js\"",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "dev:full": "npm run build && wrangler pages dev ./build",
    "check:functions": "find functions -name '*.js' -exec node --check {} \\;",
    "lighthouse": "mkdir -p .lighthouse && npx lighthouse $URL --output=json --output=html --output-path=.lighthouse/report --chrome-flags=\"--headless --no-sandbox\" --quiet --preset=desktop"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "prettier"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.5.7",
    "react-scripts": "5.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "wrangler": "^4.83.0"
  }
}
